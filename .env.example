# ==================== LLM / API Keys ====================
OPENAI_API_KEY=your_openai_api_key_here
# GEMINI_API_KEY=your_gemini_key_if_used
# GROQ_API_KEY=your_groq_key_if_used

# ==================== LangSmith / Observability ====================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=PolicyIQ-Production
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ==================== Database ====================
POSTGRES_CONNECTION=postgresql+psycopg://postgres:your_password@localhost:5433/chatbot_db
# For Render / Railway, this will be provided by the platform

POSTGRES_CONNINFO=host=localhost port=5432 dbname=chatbot_db user=postgres password=your_password

# ==================== JWT Authentication ====================
SECRET_KEY=your_super_long_random_secret_key_here_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== Redis (for rate limiting) ====================
REDIS_URL=redis://localhost:6379

# ==================== Optional ====================
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_if_using_stock_tool

# # ==================== App Settings ====================
# ENVIRONMENT=development
# # ENVIRONMENT=production   # Change this when deploying